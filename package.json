{
  "name": "pcf",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently -k -n api,web \"tsx watch src/server.ts\" \"vite\"",
    "build": "tsc -p tsconfig.server.json && vite build",
    "start": "NODE_ENV=production node dist/server/server.js",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.vercel.json && tsc -p tsconfig.app.json --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.21",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.16"
  }
}
